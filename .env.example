# ── Client (browser) — safe to expose, injected into the build ──
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Use the Supabase PUBLISHABLE key (sb_publishable_...) here.
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# ── Server-side only (Vercel env vars, never exposed to the browser) ──
# Use the Supabase SECRET key (sb_secret_...) here.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
ICAL_VACATIONS_URL=https://calendar.google.com/calendar/ical/.../private-.../basic.ics

# Only for legacy one-off migration scripts (scripts/fill-gaps.mjs)
NEON_DATABASE_URL=postgresql://user:password@host/db?sslmode=require
