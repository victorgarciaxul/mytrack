{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/tutoriales/(.*)", "destination": "/tutoriales/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/weekly-notifications",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/auto-imputacion",
      "schedule": "0 20 * * 1-5"
    }
  ]
}
