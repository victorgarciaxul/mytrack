{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/tutoriales/(.*)", "destination": "/tutoriales/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/sync-clockify",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/weekly-notifications",
      "schedule": "0 6 * * 1"
    }
  ]
}
